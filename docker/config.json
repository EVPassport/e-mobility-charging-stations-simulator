{
  "supervisionUrls": [
    "ws://voltnet.test.evpassport.com"
  ],
  "supervisionUrlDistribution": "round-robin",
  "log": {
    "file": "/dev/stdout",
    "errorFile": "/dev/stderr",
    "console": false,
    "rotate": false
  },
  "worker": {
    "processType": "workerSet",
    "elementsPerWorker": 1,
    "poolMinSize": 4,
    "poolMaxSize": 16
  },
  "uiServer": {
    "enabled": false
  },
  "stationTemplateUrls": [
    {
      "file": "ezra.station-template.json",
      "numberOfStations": 1
    }
  ]
}
